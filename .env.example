RESOLVER_PORT=4000
RESOLVER_HOST=0.0.0.0
# Comma-separated CORS allowlist. Leave empty only for local dev.
CORS_ORIGINS=

# TESTNET CONFIG
L2_RPC_URL=https://zksync-os-testnet-alpha.zksync.dev/
L1_RPC_URL=

L1_CHAIN_ID=11155111
L2_CHAIN_ID=8022833
CONTRACTS_L1_NETWORK=sepolia

# Required keys
RELAYER_L1_PRIVATE_KEY=
RELAYER_L2_PRIVATE_KEY=
L2_DEPLOYER_PRIVATE_KEY=

# Required bridge addresses after fetching/deploying deps
BRIDGEHUB_ADDRESS=0xc4fd2580c3487bba18d63f50301020132342fdbd

# LOCAL CONFIG
# L1_RPC_URL=http://localhost:8545
# L2_RPC_URL=http://localhost:3050

# L1_CHAIN_ID=31337
# L2_CHAIN_ID=6565
# CONTRACTS_L1_NETWORK=localhost

# local rich wallet
# RELAYER_L1_PRIVATE_KEY=0x7726827caac94a7f9e1b160f7ea819f172f7b6f9d2a97f992c38edeab82d4110
# RELAYER_L2_PRIVATE_KEY=0x7726827caac94a7f9e1b160f7ea819f172f7b6f9d2a97f992c38edeab82d4110
# L2_DEPLOYER_PRIVATE_KEY=0x7726827caac94a7f9e1b160f7ea819f172f7b6f9d2a97f992c38edeab82d4110

# Use contracts/script/get-bridgehub-address.ts to verify for local network
# BRIDGEHUB_ADDRESS=0xb9247a375fffc63b3383c75024946fa9c3a8601f

# ERC20 token address allowed to be bridged to alias
L1_ERC20_TOKEN_ADDRESS=

# Optional relayer tuning
MINT_VALUE_WEI_ETH_DEFAULT=2000000000000000
MINT_VALUE_WEI_ERC20_DEFAULT=3000000000000000
MAX_ATTEMPTS=5
BASE_DELAY_SECONDS=15
MAX_DELAY_SECONDS=900
RELAYER_POLL_MS=7000
# Optional gas refund recipient
REFUND_RECIPIENT_L2=

# Bridge config fetch safety defaults
AUTO_REGISTER_TOKENS=0
STRICT_TOKEN_MAPPING=1

# Optional deployments output override
CONTRACTS_JSON_PATH=

# Optional explicit path overrides (recommended for production process managers)
# ENV_FILE=/absolute/path/to/.env
# SQLITE_PATH=/absolute/path/to/services/data/poc.db
# BRIDGE_CONFIG_JSON_PATH=/absolute/path/to/infra/bridge-config.json
